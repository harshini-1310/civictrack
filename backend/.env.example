# MongoDB Connection URL
# For local development, use: mongodb://localhost:27017/citizen-connect
# For MongoDB Atlas, use: mongodb+srv://<username>:<password>@cluster.mongodb.net/citizen-connect?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/citizen-connect

# JWT Secret - Change this to a strong random string in production
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Email Configuration (Gmail SMTP)
# Get App Password at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Server Configuration
PORT=5000
NODE_ENV=development
